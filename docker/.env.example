# 🌸 若曦V2 环境变量配置示例
# 复制为 .env 并修改实际值

# =================================>
# 应用配置
# =================================>
RUOXI_ENV=production
RUOXI_DEBUG=false
RUOXI_LOG_LEVEL=INFO

# API配置
RUOXI_API_PORT=8000
RUOXI_API_HOST=0.0.0.0

# CORS (生产环境请修改为实际域名)
RUOXI_CORS_ORIGINS=["*"]

# =================================>
# 数据库配置
# =================================>
# 开发环境使用SQLite，生产环境使用PostgreSQL
RUOXI_DB_TYPE=sqlite
# SQLite路径 (开发环境)
RUOXI_DB_PATH=data/ruoxi.db

# PostgreSQL配置 (生产环境取消注释)
# RUOXI_DB_TYPE=postgresql
# RUOXI_DB_URL=postgresql://ruoxi:your_password@localhost:5432/ruoxi

# Docker Compose中PostgreSQL密码
DB_PASSWORD=your_secure_password_here

# =================================>
# AI模型配置
# =================================>
# 主模型 (gemini为首选)
RUOXI_AI_MODEL=gemini-2.0-flash
RUOXI_AI_MAX_TOKENS=4096
RUOXI_AI_TEMPERATURE=0.7

# API密钥 (生产环境请使用安全方式存储)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
TOGETHER_API_KEY=your_together_api_key_here

# 本地Ollama配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# =================================>
# 安全配置
# =================================>
# JWT密钥 (请生成随机字符串)
JWT_SECRET_KEY=your_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 加密密钥 (请生成32字节随机字符串)
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# =================================>
# 邮件配置 (用于通知)
# =================================>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=若曦 <your_email@example.com>
