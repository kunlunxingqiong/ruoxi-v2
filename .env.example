# 若曦V2 环境变量示例
# 复制此文件为 .env 并填写实际值

# 应用配置
APP_NAME=若曦V2
APP_VERSION=2.0.0
APP_DEBUG=false
APP_ENV=development

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# 数据库
DATABASE_URL=sqlite:///data/ruoxi.db
DATABASE_ECHO=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_password

# 安全配置
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 日志
LOG_LEVEL=INFO
LOG_FILE=logs/ruoxi.log
