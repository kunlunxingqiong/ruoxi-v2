# 🌸 若曦V2 - 环境变量示例配置文件
# 复制此文件为 .env 并根据实际情况修改

# ===========================================
# 基础配置
# ===========================================

# 应用环境 (development/production)
ENVIRONMENT=development

# 应用密钥 - 用于JWT等，请生成一个随机字符串
# 生产环境必须更改！
SECRET_KEY=your-secret-key-change-this-in-production

# API基础URL
API_BASE_URL=http://localhost:8000

# 前端URL (用于CORS)
FRONTEND_URL=http://localhost:3000

# ===========================================
# 数据库配置
# ===========================================

# PostgreSQL数据库
DATABASE_URL=postgresql://user:password@localhost:5432/ruoxi
# 或分段配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ruoxi
POSTGRES_USER=ruoxi_user
POSTGRES_PASSWORD=your_secure_password

# 数据库连接池设置
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===========================================
# Redis缓存配置
# ===========================================

REDIS_URL=redis://localhost:6379/0
# 或分段配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===========================================
# AI模型配置
# ===========================================

# Google Gemini API
# 获取地址: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Groq API (免费高速)
# 获取地址: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama本地模型
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# 默认AI模型 (gemini/groq/ollama)
DEFAULT_AI_PROVIDER=gemini

# ===========================================
# 向量数据库配置 (ChromaDB)
# ===========================================

CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_PERSIST_DIR=./data/chromadb

# 嵌入模型
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ===========================================
# 邮件服务配置 (可选)
# ===========================================

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key

# 或 SMTP配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@ruoxi.example.com

# ===========================================
# 推送通知配置 (可选)
# ===========================================

# Firebase Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key

# ===========================================
# 日志配置
# ===========================================

LOG_LEVEL=INFO
# 可选: DEBUG, INFO, WARNING, ERROR

LOG_FILE=logs/ruoxi.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ===========================================
# 安全设置
# ===========================================

# JWT过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 密码加密强度
BCRYPT_ROUNDS=12

# 限流设置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ===========================================
# 定时任务配置
# ===========================================

# 每日同步时间
DAILY_SYNC_HOUR=2
DAILY_SYNC_MINUTE=0

# 健康检查时间
HEALTH_CHECK_INTERVAL_MINUTES=5

# ===========================================
# 开发专用配置 (仅开发环境使用)
# ===========================================

# 调试模式
DEBUG=true

# 热重载
RELOAD=true

# 测试数据库 (开发用)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/ruoxi_test

# ===========================================
# Docker 专用配置
# ===========================================

# 这些给 docker-compose 使用
POSTGRES_IMAGE=postgres:15-alpine
REDIS_IMAGE=redis:7-alpine
CHROMADB_IMAGE=chromadb/chroma:latest

# ===========================================
# 健康指标参考值 (用于告警)
# ===========================================

# 血压
BP_SYSTOLIC_NORMAL_MAX=120
BP_SYSTOLIC_WARNING_MAX=139
BP_DIASTOLIC_NORMAL_MAX=80
BP_DIASTOLIC_WARNING_MAX=89

# 血糖 (mmol/L)
GLUCOSE_FASTING_NORMAL_MAX=6.1
GLUCOSE_FASTING_WARNING_MAX=7.0

# BMI
BMI_UNDERWEIGHT_MAX=18.5
BMI_NORMAL_MAX=23.9
BMI_OVERWEIGHT_MAX=27.9

# ===========================================
# 第三方服务 (可选)
# ===========================================

# Sentry错误追踪
SENTRY_DSN=your_sentry_dsn

# Google Analytics (前端)
GA_TRACKING_ID=your_ga_id

# ===========================================
# 备注
# ===========================================

# 1. 生产环境必须更改所有默认密钥和密码
# 2. 不要将 .env 文件提交到版本控制
# 3. 建议使用密钥管理服务保管敏感信息
# 4. 本地开发可复制此文件为 .env 后修改
