# ============================================
# 🌸 若曦配置
# ============================================

ruoxi:
  default_line: "openrouter_free"  # 默认使用OpenRouter免费
  fallback_enabled: true            # 线路失败时自动切换
  max_retries: 3                   # 最大重试次数
  timeout: 30                      # 请求超时(秒)
  
  # 不同场景偏好线路
  scenarios:
    chat: "openrouter_free"         # 日常对话
    code: "openrouter_free"         # 代码相关 (使用qwen3-coder)
    medical: "google_free"          # 医疗问答 (Gemini详细回答)
    voice: "groq_free"              # 语音场景 (Groq超快)
    offline: "none"                 # 离线模式 (使用本地llama.cpp)

# ============================================
# 🔒 安全说明
