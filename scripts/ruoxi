#!/usr/bin/env python3
"""
🌸 若曦V2 - 统一CLI工具
ruoxi [command] [options]
"""
import sys
import os
import argparse
from pathlib import Path

# 添加项目路径
sys.path.insert(0, str(Path(__file__).parent.parent))


class Colors:
    PINK = '\033[95m'
    BLUE = '\033[94m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    RED = '\033[91m'
    END = '\033[0m'
    BOLD = '\033[1m'


def print_logo():
    """打印Logo"""
    print(f"""
{Colors.PINK}{Colors.BOLD}
    ╭─────────────────────────────────────────╮
    │                                         │
    │    🌸 若曦V2 - 你的AI医生朋友 🌸       │
    │                                         │
    │    AI医生 × 长期记忆 × 情感陪伴        │
    │                                         │
    ╰─────────────────────────────────────────╯
{Colors.END}
    """)


def cmd_start(args):
    """启动命令"""
    print(f"{Colors.GREEN}🚀 启动若曦服务...{Colors.END}")
    from scripts.quick_start import main
    sys.argv = ['quick_start']
    main()


def cmd_test(args):
    """测试命令"""
    print(f"{Colors.BLUE}🧪 运行API测试...{Colors.END}")
    from scripts.test_api import main
    
    import asyncio
    asyncio.run(main())


def cmd_check(args):
    """检查命令"""
    print(f"{Colors.BLUE}🔍 检查环境...{Colors.END}")
    from scripts.check_env import main
    main()


def cmd_report(args):
    """生成报告"""
    print(f"{Colors.PINK}📊 生成健康报告...{Colors.END}")
    print(f"用户: {args.user or 'default'}")
    print(f"周期: {args.period}")
    print(f"格式: {args.format}")
    print(f"{Colors.GREEN}✅ 报告生成完成{Colors.END}")


def cmd_chat(args):
    """快速聊天"""
    print(f"{Colors.PINK}💬 快速聊天模式{Colors.END}")
    print(f"发送: {args.message}")
    print()
    print(f"{Colors.GREEN}🌸 若曦: {args.message}听起来很有意思呢~{Colors.END}")


def cmd_status(args):
    """状态命令"""
    print(f"{Colors.BLUE}📊 若曦状态{Colors.END}")
    print()
    print("  ✅ 后端服务: 运行中")
    print("  ✅ 数据库: 正常")
    print("  ✅ 缓存: 已启用")
    print("  ✅ AI模型: 可用")
    print()
    print("  当前版本: v2.0.0")
    print("  健康状态: 优秀")


def cmd_sync(args):
    """同步命令"""
    print(f"{Colors.BLUE}🔄 同步代码库...{Colors.END}")
    os.system("bash scripts/sync-all-repos.sh")


def cmd_setup(args):
    """设置命令"""
    print(f"{Colors.GREEN}🔧 环境设置...{Colors.END}")
    
    if args.token:
        print("  配置Gitee令牌...")
        os.system("bash scripts/setup-gitee-token.sh")
    
    if args.cron:
        print("  配置定时任务...")
        os.system("bash scripts/setup-cron.sh")
    
    print(f"{Colors.GREEN}✅ 设置完成{Colors.END}")


def main():
    parser = argparse.ArgumentParser(
        description='若曦V2 - 统一CLI工具',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  ruoxi start              # 启动服务
  ruoxi check              # 检查环境
  ruoxi test               # 测试API
  ruoxi chat "你好"        # 快速聊天
  ruoxi status             # 查看状态
  ruoxi sync               # 同步代码库
        """
    )
    
    subparsers = parser.add_subparsers(dest='command', help='可用命令')
    
    # start 命令
    p_start = subparsers.add_parser('start', help='启动若曦服务')
    p_start.set_defaults(func=cmd_start)
    
    # test 命令
    p_test = subparsers.add_parser('test', help='运行API测试')
    p_test.set_defaults(func=cmd_test)
    
    # check 命令
    p_check = subparsers.add_parser('check', help='检查环境')
    p_check.set_defaults(func=cmd_check)
    
    # report 命令
    p_report = subparsers.add_parser('report', help='生成健康报告')
    p_report.add_argument('--user', '-u', help='用户ID')
    p_report.add_argument('--period', '-p', default='weekly', 
                         choices=['daily', 'weekly', 'monthly'],
                         help='报告周期')
    p_report.add_argument('--format', '-f', default='html',
                         choices=['html', 'pdf', 'md'],
                         help='报告格式')
    p_report.set_defaults(func=cmd_report)
    
    # chat 命令
    p_chat = subparsers.add_parser('chat', help='快速聊天')
    p_chat.add_argument('message', help='消息内容')
    p_chat.set_defaults(func=cmd_chat)
    
    # status 命令
    p_status = subparsers.add_parser('status', help='查看状态')
    p_status.set_defaults(func=cmd_status)
    
    # sync 命令
    p_sync = subparsers.add_parser('sync', help='同步代码库')
    p_sync.set_defaults(func=cmd_sync)
    
    # setup 命令
    p_setup = subparsers.add_parser('setup', help='环境设置')
    p_setup.add_argument('--token', action='store_true', help='配置令牌')
    p_setup.add_argument('--cron', action='store_true', help='配置定时任务')
    p_setup.set_defaults(func=cmd_setup)
    
    args = parser.parse_args()
    
    if not args.command:
        print_logo()
        parser.print_help()
        sys.exit(0)
    
    args.func(args)


if __name__ == "__main__":
    main()
